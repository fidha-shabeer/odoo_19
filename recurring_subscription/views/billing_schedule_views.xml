<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="billing_schedule_list_view" model="ir.ui.view">
            <field name="name">billing.schedule.list</field>
            <field name="model">billing.schedule</field>
            <field name="arch" type="xml">
                <list string="Billing Schedule List" >
                    <field name="is_simulation"/>
                    <field name="names"/>
                    <field name="period"/>
                    <field name="restrict_customers_ids" widget="many2many_tags"/>
                    <field name="total_credits"/>
                </list>
            </field>
        </record>

        <record id="billing_schedule_form_view" model="ir.ui.view">
                    <field name="name">billing.schedule.form</field>
                    <field name="model">billing.schedule</field>
                    <field name="arch" type="xml">
                        <form>
                            <header>
                                <button name="action_billing" string="Bill" class="oe_highlight" type="object"/>
                            </header>
                            <sheet>
                                <div class="oe_button_box" name="button_box">
                                    <button name="action_view_subscription" type="object"
                                            class="oe_stat_button" icon="fa-book"
                                            invisible = 'subscription_count == 0 '>
                                        <field name="subscription_count" widget="statinfo" string="Subscription Count"/>
                                    </button>
<!--                                     <button name="action_view_invoice" type="object"-->
<!--                                            class="oe_stat_button" icon="fa fa-book"-->
<!--                                            invisible = 'subscription_count == 0 '>-->
<!--                                        <field name="subscription_count" widget="statinfo" string="Subscription Count"/>-->
<!--                                    </button>-->
                                </div>

                                <group>
                                    <group>
                                        <field name="names"/>
                                        <field name="period"/>
                                        <field name="is_simulation"/>
                                        <field name="active"/>
                                    </group>
                                        <group>
                                            <field name="subscription_ids" widget="many2many_tags"/>
                                            <field name="restrict_customers_ids" widget="many2many_tags"/>
                                             <field name="total_credits"/>
                                        </group>

                                </group>
                                <notebook>
                                    <page string="Credits">
                                        <group>
                                            <field name="credit_rec_ids" nolabel="1"/>
                                        </group>
                                    </page>
                                </notebook>
                            </sheet>
                            <chatter/>
                        </form>
                    </field>
                </record>
    <record id="action_billing_schedule" model="ir.actions.act_window">
       <field name="name">Billing Schedule</field>
       <field name="res_model">billing.schedule</field>

       <field name="view_mode">list,form</field>
       <field name="help" type="html">
           <p class="o_view_noncontent_smiling_face">ADD!!</p>
       </field>
   </record>
    </data>
</odoo>