<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="recurring_credit_list_view" model="ir.ui.view">
            <field name="name">rec.credit.list</field>
            <field name="model">recurring.credit</field>
            <field name="arch" type="xml">
                <list string="Recurring Subscription Credit List">
                    <field name="recurring_sub_id"/>
                    <field name="partner_id"/>
                    <field name="currency_id" />
                    <field name="credit_amounts"/>
                    <field name="state"/>
                    <field name="period"/>
                </list>
            </field>
        </record>

     <record id="recurring_sub_form_view2" model="ir.ui.view">
                    <field name="name">rec.credit.form</field>
                    <field name="model">recurring.credit</field>
                    <field name="arch" type="xml">
                        <form string="Recurring Subscription Credit">
                            <header>
                                <field name="state" widget="statusbar" options="{'clickable':1}"/>
                            </header>
                            <sheet>
                                <group>
                                    <field name="recurring_sub_id"/>
                                    <field name="id_establishment"/>
                                    <field name="due_date"/>
                                    <field name="partner_id"/>
                                    <field name="recurring_amounts"/>
                                    <field name="company_id"/>
                                    <field name="currency_id" invisible="1"/>
                                    <field name="credit_amounts"/>
                                    <field name="period"/>
                                </group>
                            </sheet>
                            <chatter/>
                        </form>
                    </field>
                </record>

   <record id="action_recurring_credit" model="ir.actions.act_window">
       <field name="name">Subscription Credit</field>
       <field name="res_model">recurring.credit</field>

       <field name="view_mode">list,form</field>
       <field name="help" type="html">
           <p class="o_view_noncontent_smiling_face">add new</p>
       </field>
   </record>
</odoo>