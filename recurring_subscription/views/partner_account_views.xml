<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
     <record id="partner_account_list_view" model="ir.ui.view">
            <field name="name">partner.account.list.view</field>
            <field name="model">partner.account</field>
            <field name="arch" type="xml">
                <list string="Partner Account ID list" >
                    <field name="account_no"/>
                </list>
            </field>
        </record>

        <record id="partner_account_form_view" model="ir.ui.view">
            <field name="name">partner.account.form.view</field>
            <field name="model">partner.account</field>
            <field name="arch" type="xml">
            <form>
                <sheet>
                     <group>
                         <group>
                             <field name="account_no"/>
                         </group>

                     </group>
                </sheet>
                <chatter/>
            </form>
            </field>
        </record>

      <record id="action_partner_account" model="ir.actions.act_window">
       <field name="name">Partner Account ID</field>
       <field name="res_model">partner.account</field>
       <field name="view_mode">list,form</field>
       <field name="help" type="html">
           <p class="o_view_noncontent_smiling_face">No Account No. Added!!</p>
       </field>
   </record>
    </data>
</odoo>